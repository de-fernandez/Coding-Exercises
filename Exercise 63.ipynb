   "source": [
    "Very simple, given a number, find its opposite (additive inverse).\n",
    "\n",
    "Examples:<br>\n",
    "\n",
    "1: -1<br>\n",
    "14: -14<br>\n",
    "-34: 34"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "909a1c98",
   "metadata": {},
   "outputs": [],
   "source": [
    "def opposite(number):\n",
    "    return -number"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "1b70f81e",
   "metadata": {},
   "outputs": [
    {
     "data": {
