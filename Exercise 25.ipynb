   "source": [
    "Complete the method that takes a boolean value and return a \"Yes\" string for true, or a \"No\" string for false."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "3023629e",
   "metadata": {},
   "outputs": [],
   "source": [
    "def bool_to_word(boolean):\n",
    "    return \"Yes\" if boolean == True else \"No\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "a5d6f2a2",
   "metadata": {},
   "outputs": [
    {
     "data": {
