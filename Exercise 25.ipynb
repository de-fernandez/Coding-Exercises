       "'No'"
      ]
     },
     "execution_count": 2,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "bool_to_word(False) # No"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "d399e7eb",
   "metadata": {},
   "outputs": [
    {
     "data": {
