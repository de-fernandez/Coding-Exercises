   "source": [
    "Make a function that returns the value multiplied by 50 and increased by 6. If the value entered is a string it should return \"Error\".\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "6bd93620",
   "metadata": {},
   "outputs": [],
   "source": [
    "def problem(a):\n",
    "    if isinstance(a, (int, float)):\n",
    "        return (a * 50) + 6\n",
    "    else:\n",
    "        return \"Error\""
   ]
  },
