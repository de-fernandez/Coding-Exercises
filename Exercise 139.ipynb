   "source": [
    "Write a function that always returns 5\n",
    "\n",
    "Sounds easy right? Just bear in mind that you can't use any of the following characters: 0123456789*+-/\n",
    "\n",
    "Good luck :)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "2da38377",
   "metadata": {},
   "outputs": [],
   "source": [
    "def unusual_five():\n",
    "    result = [\"a\", \"b\", \"c\", \"d\", \"e\"]\n",
    "    return len(result)"
   ]
